@app.route('/time_frame', methods=['GET', 'POST'])
def time_frame():
    filename = "stock.json"
    message = ""
    data = []

    # Load existing orders
    if os.path.exists(filename):
        with open(filename) as f:
            try:
                data = json.load(f)
            except json.JSONDecodeError:
                data = []

    if request.method == 'POST':
        prod = request.form.get('prod')
        stock_order = int(request.form.get('stock_order', 0))
        variance = int(request.form.get('variance', 0))
        order = stock_order - variance
        season = request.form.get('season')

        sys_data = {
            'zone': 'cat',
            'prod': prod,
            'stock_order': stock_order,
            'variance': variance,
            'order': order,
            'season': season
        }
        data.append(sys_data)
        with open(filename, 'w') as f:
            json.dump(data, f, indent=4)
        message = "Order and data updated."
    form_html = Markup("""
        <br><a href='/'">home</a></br>
        <h3>Order Trajectory on Timeframe</h3>
        <form method="post">
            <label>Product:</label><input name="prod"><br>
            <label>Last Order Amount:</label><input type="number" name="stock_order"><br>
            <label>Variance (demand - on shelf):</label><input type="number" name="variance"><br>
            <label>Season:</label>
                <select name="season">
                    <option>winter</option>
                    <option>spring</option>
                    <option>summer</option>
                    <option>fall</option>
                </select><br>
            <button type="submit">Update Order</button>
        </form>
        <hr>
    """)
    display_html = Markup("<h4>Order History</h4>")
    if data:
        for d in reversed(data[-5:]):  # show last 5
            display_html += Markup(
                f"<div>Product: {d['prod']}, Order: {d['order']}, Season: {d['season']}</div>"
            )
    bodyText = message + form_html + display_html
    return render_template('template.html', titleText="Timeframe", bodyText=bodyText)
if __name__ == '__main__':
    app.run(host='0.0.0.0', debug=True)
