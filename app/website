@app.route('/zone', methods=['GET', 'POST'])
def zone():
    import json, os
    filename = "data.json"
    inventory = {"freezer": [], "fridge": [], "dry": []}
    # Load existing data
    if os.path.exists(filename):
        with open(filename) as f:
            saved = json.load(f)
            if isinstance(saved, dict):
                inventory.update(saved)
    message = ""
    if request.method == 'POST':
        zone = request.form.get('zone')
        item = request.form.get('item')
        if zone in inventory and item:
            inventory[zone].append(item)
            message = f"Added {item} to {zone}"
            with open(filename, "w") as f:
                json.dump(inventory, f, indent=4)
    bodyText = Markup("""
        <form method="post">
          <label>Zone</label>
          <select name="zone">
            <option value="freezer">Freezer</option>
            <option value="fridge">Fridge</option>
            <option value="dry">Dry</option>
          </select><br>
          <label>Item</label>
          <input name="item"><br>
          <button type="submit">Add Item</button>
        </form>
        <hr>""")
    bodyText += f"<p>{message}</p>"
    for k,v in inventory.items():
        bodyText += f"<p><b>{k.title()}</b>: {', '.join(map(str, v))}</p>"

    bodyText += Markup("<br><a href='/'>home</a>")
    return render_template('template.html', titleText="Zone Inventory", bodyText=bodyText)
